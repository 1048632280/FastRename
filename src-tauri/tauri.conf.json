{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FastRename",
  "version": "0.1.0",
  "identifier": "com.fastrename.app",
  "mainBinaryName": "fastrename",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FastRename",
        "width": 1120,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "publisher": "FastRename Contributors",
    "shortDescription": "极速文件重命名工具",
    "longDescription": "FastRename 是一款 Windows 桌面端本地文件重命名工具，支持精准编辑、即时落盘和运行期撤销。",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
